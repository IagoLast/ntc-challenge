# --- Base de datos (Vercel Postgres / Neon) ---
# Al conectar la integración de Vercel Postgres o Neon en el dashboard de Vercel,
# estas variables se rellenan automáticamente. Para desarrollo local copia este
# archivo a .env.local y pega tu connection string.
POSTGRES_URL="postgres://usuario:password@host/db?sslmode=require"

# --- Vercel Blob (almacenamiento de vídeos e imágenes) ---
# Se crea automáticamente al añadir un Blob Store en Vercel.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- Panel de administración ---
# Slug secreto del panel de admin. La URL será /admin/<ADMIN_SECRET>.
# Cámbialo por algo que solo sepas tú. Si no se define, se usa "ntc"
# (es decir, el panel estaría en /admin/ntc).
ADMIN_SECRET="cambia-esto-por-algo-secreto"
